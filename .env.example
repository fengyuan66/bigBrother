# Copy this file to .env and fill in your Hack Club AI key.

BIG_BROTHER_API_KEY=
BIG_BROTHER_BASE_URL=https://ai.hackclub.com/proxy/v1
BIG_BROTHER_MODEL=google/gemini-2.5-flash

BIG_BROTHER_INTERVAL_SECONDS=8
BIG_BROTHER_OFF_TASK_THRESHOLD=2

BIG_BROTHER_DEMO_BROWSER=Chrome
BIG_BROTHER_DEMO_URL=https://en.wikipedia.org/wiki/Calculus
BIG_BROTHER_DEMO_INTERVAL_SECONDS=2
