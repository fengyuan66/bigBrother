# Copy this file to .env and fill in your Hack Club AI key.

BIG_BROTHER_API_KEY=
BIG_BROTHER_BASE_URL=https://ai.hackclub.com/proxy/v1
BIG_BROTHER_MODEL=google/gemini-2.5-flash
BIG_BROTHER_WATCHER_MODEL=qwen/qwen3-32b
BIG_BROTHER_MPA_MODEL=qwen/qwen3-32b
BIG_BROTHER_PERSONALITY_MODEL=qwen/qwen3-32b
BIG_BROTHER_VISION_MODEL=qwen/qwen3-vl-235b-a22b-instruct
BIG_BROTHER_PERSONALITY_BRIEF=Direct, warm, slightly assertive, and human. Keep the user focused without sounding robotic.

# Optional explicit resource paths for the watcher.
# BIG_BROTHER_WEBCAM_PATH=sources/webcam/latest.txt
# BIG_BROTHER_SCREENSHARE_PATH=sources/video/latest.txt
# BIG_BROTHER_BROWSER_PATH=sources/browser/browser_live.txt

BIG_BROTHER_INTERVAL_SECONDS=4
BIG_BROTHER_OFF_TASK_THRESHOLD=1

BIG_BROTHER_DEMO_BROWSER=Edge
BIG_BROTHER_DEMO_URL=https://www.google.com
BIG_BROTHER_DEMO_INTERVAL_SECONDS=4
BIG_BROTHER_POST_SPEECH_PAUSE_SECONDS=15

ELEVENLABS_API_KEY=
BIG_BROTHER_ELEVENLABS_VOICE_ID=
BIG_BROTHER_ELEVENLABS_MODEL_ID=eleven_multilingual_v2
BIG_BROTHER_ELEVENLABS_STABILITY=0.45
BIG_BROTHER_ELEVENLABS_SIMILARITY=0.8
